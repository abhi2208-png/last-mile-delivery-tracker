{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "types": ["node"]
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist",
    "prisma.config.ts"
  ]
}
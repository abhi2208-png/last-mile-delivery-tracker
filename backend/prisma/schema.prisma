generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  ADMIN
  CUSTOMER
  AGENT
}

enum OrderType {
  B2B
  B2C
}

enum PaymentType {
  PREPAID
  COD
}

enum OrderStatus {
  CREATED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      Order[] @relation("CustomerOrders")
  agentOrders Order[] @relation("AgentOrders")
}

model Zone {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  pickupRates RateCard[] @relation("PickupZone")
  dropRates   RateCard[] @relation("DropZone")

  pickupOrders Order[] @relation("PickupZoneOrders")
  dropOrders   Order[] @relation("DropZoneOrders")

  areas Area[]
}

model Area {
  id   String @id @default(cuid())
  name String @unique

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])
}

model RateCard {
  id String @id @default(cuid())

  pickupZoneId String
  dropZoneId   String

  pickupZone Zone @relation("PickupZone", fields: [pickupZoneId], references: [id])
  dropZone   Zone @relation("DropZone", fields: [dropZoneId], references: [id])

  orderType OrderType

  pricePerKg Float

  codCharge Float

  createdAt DateTime @default(now())
}

model Order {
  id String @id @default(cuid())

  customerId String
  customer   User   @relation("CustomerOrders", fields: [customerId], references: [id])

  agentId String?
  agent   User?   @relation("AgentOrders", fields: [agentId], references: [id])

  pickupAddress String
  dropAddress   String

  pickupZoneId String
  dropZoneId   String

  pickupZone Zone @relation("PickupZoneOrders", fields: [pickupZoneId], references: [id])

  dropZone Zone @relation("DropZoneOrders", fields: [dropZoneId], references: [id])

  length  Float
  breadth Float
  height  Float

  actualWeight Float

  volumetricWeight Float

  billableWeight Float

  charge Float

  paymentType PaymentType

  orderType OrderType

  status OrderStatus @default(CREATED)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  tracking TrackingHistory[]

  notifications Notification[]

  reschedules Reschedule[]

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([pickupZoneId])
  @@index([dropZoneId])
}

model TrackingHistory {
  id String @id @default(cuid())

  orderId String

  order Order @relation(fields: [orderId], references: [id])

  status OrderStatus

  updatedBy String

  timestamp DateTime @default(now())
}

model Notification {
  id String @id @default(cuid())

  orderId String

  order Order @relation(fields: [orderId], references: [id])

  emailSent Boolean @default(false)

  smsSent Boolean @default(false)

  createdAt DateTime @default(now())
}

model Reschedule {
  id String @id @default(cuid())

  orderId String

  order Order @relation(fields: [orderId], references: [id])

  newDate DateTime

  reason String

  createdAt DateTime @default(now())
}
